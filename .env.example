# Your domain, pointed at this server (A/AAAA record). Caddy fetches HTTPS certs automatically.
DOMAIN=spots.example.com

# Password for the bundled PostgreSQL (internal only, not exposed).
POSTGRES_PASSWORD=change-me

# Optional: fix the JWT signing secret. If unset, one is generated on first
# boot and persisted in the photos volume.
#JWT_SECRET=
